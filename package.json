{
  "name": "git-identity-switcher",
  "displayName": "Git Identity Switcher",
  "description": "Show the current git user identity in the VS Code status bar",
  "version": "1.0.0",
  "publisher": "seiya-koji",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/seiya-koji/git-identity-switcher"
  },
  "license": "MIT",
  "keywords": [
    "git",
    "identity",
    "user",
    "email",
    "profile",
    "switch"
  ],
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "activationEvents": [
    "workspaceContains:.git"
  ],
  "icon": "images/icon.png",
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gitIdentity.refresh",
        "title": "Git Identity: Refresh Status Bar"
      }
    ],
    "configuration": {
      "title": "Git Identity",
      "properties": {
        "gitIdentity.statusBar.priority": {
          "type": "number",
          "default": 100,
          "description": "Status bar item priority (higher = further left)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies",
    "prepare": "husky",
    "test": "vitest run",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^20",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "prettier": "^3.8.4",
    "typescript": "^5.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
